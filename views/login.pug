extends layout

block content
  section.auth-page
    .auth-card
      p.eyebrow Welcome back
      h1 Login
      p Sign in to connect checkout orders to your profile purchase history.
      if error
        .alert.alert-error= error
      form(method="post", action="/login")
        .form-group
          label(for="email") Email
          input#email(type="email", name="email", value=values.email, required)
        .form-group
          label(for="password") Password
          input#password(type="password", name="password", required)
        button.btn.btn-wide(type="submit") Login
      p.auth-note Need an account? #[a(href="/register") Create one]
